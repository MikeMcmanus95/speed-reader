{
  "name": "speed-reader-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@speed-reader/web",
    "dev:extension": "turbo run dev --filter=@speed-reader/extension",
    "harness:check": "node harness/scripts/check-harness.cjs",
    "harness:eval": "node harness/scripts/run-evals.cjs",
    "ci:required": "pnpm harness:check && pnpm harness:eval && (cd backend && GOCACHE=\"$PWD/../.cache/go-build\" go test ./...)",
    "ci:full": "pnpm lint && pnpm typecheck && pnpm test",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "ajv@<6.14.0": "6.14.0",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "rollup@<2.80.0": "2.80.0",
      "rollup@>=4.0.0 <4.59.0": "4.59.0"
    }
  }
}
